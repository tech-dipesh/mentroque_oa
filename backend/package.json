{
  "name": "mentorque-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "bun  dist/server.js",
    "seed": "bunx prisma migrate dev --name init",
    "migrate": "bunx prisma migrate dev",
    "generate": "bunx prisma generate",
    "studio": "bunx prisma studio",
    "validate": "bunx prisma validate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "reset": "bunx prisma migrate reset"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.9.0",
    "@prisma/client": "^7.9.0",
    "@xenova/transformers": "^2.17.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "jsonwebtoken": "^9.0.3",
    "sharp": "^0.35.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.20.1",
    "prisma": "^7.9.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  }
}
